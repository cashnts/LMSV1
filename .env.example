# Clerk (web + use CLERK_SECRET_KEY in API if you add Clerk verification later)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Supabase (same project for web + API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Legacy anon key still works if publishable not set:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Nest API
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001/api
APP_ADMIN_USER_IDS=user_123,user_456
# Optional alternative to IDs:
APP_ADMIN_EMAILS=admin@example.com

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Bunny.net (optional — replaces Supabase Storage for video/image/file uploads)
# Bunny Stream (videos — transcoding + HLS streaming)
BUNNY_STREAM_LIBRARY_ID=        # Library ID from Bunny Stream dashboard
BUNNY_STREAM_API_KEY=           # Stream API key (not account API key)
BUNNY_STREAM_CDN_HOSTNAME=      # e.g. vz-xxxxxxxx.b-cdn.net (from Stream > CDN Hostname)

# Bunny Storage (images + files)
BUNNY_STORAGE_ZONE=             # Storage zone name
BUNNY_STORAGE_ACCESS_KEY=       # FTP/API password from storage zone
BUNNY_STORAGE_CDN_URL=          # Pull zone URL, e.g. https://myzone.b-cdn.net
BUNNY_STORAGE_REGION=ny         # Storage region: ny, la, sg, se, uk, de (default: ny)

DOMAIN=