{
  "name": "lms-saas",
  "private": true,
  "scripts": {
    "dev": "pnpm run --parallel dev:api dev:web",
    "dev:api": "pnpm --filter @lms/api start:dev",
    "dev:web": "pnpm --filter @lms/web dev",
    "build:web": "pnpm --filter @lms/web build",
    "build": "pnpm run -r build",
    "lint": "pnpm run -r lint"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "supabase": "^2.92.1"
  }
}
